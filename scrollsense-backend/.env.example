# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/scrollsense

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# JWT
JWT_ACCESS_SECRET=your_long_random_access_secret_min_64_chars
JWT_REFRESH_SECRET=your_long_random_refresh_secret_min_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# Redis (Upstash)
REDIS_URL=redis://default:<password>@<host>.upstash.io:6379

# AWS S3 (Instagram file temp storage)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
AWS_S3_BUCKET=scrollsense-instagram-temp

# Nodemailer (weekly digest)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
DIGEST_FROM_EMAIL=digest@scrollsense.app